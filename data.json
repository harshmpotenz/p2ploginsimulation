        "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChZDSUhNMG9nS0VJQ0FnSUNYbmVtU0tnEAE!2m1!1s0x89b62d22c8e472a9:0x64ad260b1683b62f"
