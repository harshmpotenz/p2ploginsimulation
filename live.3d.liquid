  function drawCanvasMockup(targetCanvas, assets, view = "front") {
    if (!targetCanvas || !assets?.frontCanvas || !assets?.rightCanvas || !assets?.topCanvas) {
      return;
    }

    const sourceFrontW = assets.frontCanvas.width || assets.frontWidth || 1;
    const sourceFrontH = assets.frontCanvas.height || assets.frontHeight || 1;
    const sourceEdgeW = assets.rightCanvas.width || assets.edgeSize || 1;
    const sourceEdgeH = assets.topCanvas.height || assets.edgeSize || 1;
    const aspectRatio = (sourceFrontW + sourceEdgeW * 1.4) / (sourceFrontH + sourceEdgeH * 1.2);
    const resized = resizePreviewCanvas(targetCanvas, aspectRatio);

    if (!resized) return;

    const { ctx, width, height } = resized;
    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = "#f7f7f5";
    ctx.fillRect(0, 0, width, height);

    const strongerAngle = view === "right";
    const frontW = width * (strongerAngle ? 0.38 : 0.56);
    const frontH = frontW * (sourceFrontH / sourceFrontW);
    const sideW = Math.max(frontW * (sourceEdgeW / sourceFrontW), strongerAngle ? frontW * 0.34 : frontW * 0.18);
    const topH = Math.max(frontH * (sourceEdgeH / sourceFrontH), strongerAngle ? frontH * 0.18 : frontH * 0.1);
    const frontX = (width - frontW - sideW * 0.7) / 2;
    const frontY = (height - frontH - topH * 0.75) / 2;
    const topSkew = strongerAngle ? -0.85 : -0.55;
    const sideSkew = strongerAngle ? 0.45 : 0.28;

    ctx.save();
    ctx.shadowColor = "rgba(0, 0, 0, 0.18)";
    ctx.shadowBlur = strongerAngle ? 32 : 24;
    ctx.shadowOffsetY = strongerAngle ? 26 : 18;
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(frontX, frontY, frontW, frontH);
    ctx.restore();

    drawParallelogramImage(
      ctx,
      assets.topCanvas,
      frontX + topH * Math.abs(topSkew),
      frontY - topH,
      frontW,
      topH,
      topSkew,
      0
    );

    drawParallelogramImage(
      ctx,
      assets.rightCanvas,
      frontX + frontW,
      frontY,
      sideW,
      frontH,
      0,
      sideSkew
    );

    ctx.drawImage(assets.frontCanvas, frontX, frontY, frontW, frontH);

    ctx.strokeStyle = "rgba(17, 17, 17, 0.08)";
    ctx.lineWidth = 1;
    ctx.strokeRect(frontX, frontY, frontW, frontH);
  }

  function renderCanvasPreviewsFromAssets(assets) {
