 <script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>
   
<script>
(function() {
  'use strict';

  // ============================================
  // GLOBAL VARIABLES (shared across functions)
  // ============================================
  let imageURL = null;
  let origW = 0;
  let origH = 0;
  let aspect = 1;
  let isImageLoaded = false;
  let currentImageLoading = null;
  let loadedImg = null;
  let imageSrc = null;
  let imageRatio = 1; // width/height
  
  // Three.js globals
  let scene, camera, renderer, wrapGroup, currentMesh;
  const container = document.getElementById("threeContainer");

  // DOM elements
  const upload = document.getElementById("upload");
  const canvases = document.querySelectorAll(".canvas-preview");
  const fWidthInput = document.getElementById("fWidth");
  const fHeightInput = document.getElementById("fHeight");
  const origfWidthInput = document.getElementById("ofWidth");
  const origfHeightInput = document.getElementById("ofHeight");
  const depthInput = document.getElementById("depth");
  const ratioInput = document.getElementById("ratio");
  const scaleInput = document.getElementById("scale");
  const leftOffsetInput = document.getElementById("leftOffset");
  const topOffsetInput = document.getElementById("topOffset");
 
  const imgWidthInput = document.getElementById("imgWidth");
  const imgHeightInput = document.getElementById("imgHeight");
  const canvasImgWidthInput = document.getElementById("canvasImgWidth");
  const canvasImgHeightInput = document.getElementById("canvasImgHeight");
  const previewImgWidthInput = document.getElementById("previewImgWidth");
  const previewImgHeightInput = document.getElementById("previewImgHeight");
  const lockAspect = document.getElementById("lockAspect");
  const useCustomSize = document.getElementById("useCustomSize");
  const backFoldInput = document.getElementById("backFold");
  const noImageMessage = document.getElementById("noImageMessage");
  const closeNoImageMessage = document.getElementById("closeNoImageMessage");
  const previewBtn = document.querySelector("#preview-popup");
  const popup = document.getElementById("canvasPopup");
  const frontPreviewCanvas = document.getElementById("frontPreviewCanvas");
  const rightPreviewCanvas = document.getElementById("rightPreviewCanvas");

  const zoom = document.getElementById("zoom");
  const frameBottom = document.getElementById("frameBottom");
  const bottomValue = document.getElementById("bottomValue");
  const zoomValue = document.getElementById("zoomValue");
      
  const canvasStage = document.getElementById('canvasStage');
  const stageCanvas = document.getElementById('stageCanvas');
  const ctx = stageCanvas ? stageCanvas.getContext('2d') : null;

  const REAL_BG_SIZE = { width: 5000, height: 5000 };
  const BACKGROUND_IMAGE_URL = "https://cdn.shopify.com/s/files/1/0926/7786/5836/files/background_3.png?v=1772096849";
  const bgImage = new Image();
  const artImage = new Image();
  bgImage.src = BACKGROUND_IMAGE_URL;
  bgImage.onload = () => render();
  artImage.onload = () => render();
  let previewAssets = null;
  
  // ============================================
  // UTILITY FUNCTIONS
  // ============================================
  function showLoading() {
    const loadingEl = document.getElementById("canvasLoading");
    if (loadingEl) loadingEl.classList.add("active");
    canvases.forEach(canvas => { canvas.style.visibility = 'hidden'; });
  }

  function hideLoading() {
    const loadingEl = document.getElementById("canvasLoading");
    if (loadingEl) loadingEl.classList.remove("active");
    if (isImageLoaded) {
      canvases.forEach(canvas => { canvas.style.visibility = 'visible'; });
    }
  }

  function showToast(message, duration = 3000) {
    let toast = document.querySelector(".custom-toast");
    if (!toast) {
      toast = document.createElement("div");
      toast.className = "custom-toast";
      document.body.appendChild(toast);
    }
    toast.textContent = message;
    toast.classList.add("show");
    setTimeout(() => toast.classList.remove("show"), duration);
  }

  function getVal(id) {
    const el = document.getElementById(id);
    if (!el) return "";
    if (el.value !== undefined && el.value !== null && el.value !== "") return el.value;
    if (el.textContent && el.textContent.trim() !== "") return el.textContent.trim();
    return "";
  }

  function getEditorPreviewAssets() {
    if (typeof window.getP2PPreviewAssets === "function") {
      try {
        return window.getP2PPreviewAssets(1400);
      } catch (error) {
        console.error("Failed to read editor preview assets:", error);
      }
    }

    return null;
  }

  function resizePreviewCanvas(canvasEl, aspectRatio = 1) {
    if (!canvasEl) return null;

    const parent = canvasEl.parentElement;
    const parentWidth = parent?.clientWidth || 600;
    const parentHeight = parent?.clientHeight || 600;
    const safeAspect = aspectRatio > 0 ? aspectRatio : 1;

    let width = parentWidth;
    let height = width / safeAspect;

    if (height > parentHeight) {
      height = parentHeight;
      width = height * safeAspect;
    }

    const dpr = window.devicePixelRatio || 1;
    canvasEl.width = Math.max(1, Math.round(width * dpr));
    canvasEl.height = Math.max(1, Math.round(height * dpr));
    canvasEl.style.width = `${Math.round(width)}px`;
    canvasEl.style.height = `${Math.round(height)}px`;

