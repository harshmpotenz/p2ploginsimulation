    if (previewAssets?.frontCanvas) return previewAssets;

    const mainImgWrap = document.querySelector(".main-img-wrap");
    if (mainImgWrap) {
      if (mainImgWrap.dataset?.mainImg) return mainImgWrap.dataset.mainImg;
      if (mainImgWrap.getAttribute('data-main-img')) return mainImgWrap.getAttribute('data-main-img');
