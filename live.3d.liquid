function loadImage(imgSrc) {
  return new Promise((resolve, reject) => {
    showLoading();
    isImageLoaded = false;

    if (currentImageLoading) {
      currentImageLoading.onload = null;
      currentImageLoading.onerror = null;
    }

    if (imgSrc && typeof imgSrc === "object" && imgSrc.frontCanvas) {
      previewAssets = imgSrc;
      currentImageLoading = null;
      loadedImg = imgSrc.wrapCanvas || imgSrc.frontCanvas;
      imageURL = "__editor_preview__";
      origW = imgSrc.wrapWidth || imgSrc.wrapCanvas?.width || imgSrc.frontCanvas.width || 0;
      origH = imgSrc.wrapHeight || imgSrc.wrapCanvas?.height || imgSrc.frontCanvas.height || 0;
      aspect = origW ? origH / origW : 1;
      isImageLoaded = true;

      if (imgWidthInput) imgWidthInput.value = origW;
      if (imgHeightInput) imgHeightInput.value = origH;
      if (canvasImgWidthInput) canvasImgWidthInput.value = origW;
      if (canvasImgHeightInput) canvasImgHeightInput.value = origH;

      renderCanvasPreviewsFromAssets(imgSrc);
      setTimeout(() => {
        updateThreePreview();
        render();
      }, 50);
      hideLoading();
      resolve(imgSrc);
      return;
    }

    const img = new Image();
    currentImageLoading = img;
    loadedImg = img;
    previewAssets = null;
    
    // CRITICAL FIX: Also set the artImage for 2D context
    artImage.src = imgSrc;

    if (!imgSrc.startsWith('data:') && !imgSrc.startsWith('blob:')) {
      img.crossOrigin = "anonymous";
    }

    const timeoutId = setTimeout(() => {
      console.error("Image loading timeout");
      hideLoading();
      reject(new Error("Timeout"));
    }, 15000);

    img.onload = () => {
      clearTimeout(timeoutId);

      origW = img.naturalWidth;
      origH = img.naturalHeight;
      aspect = origH / origW;
      isImageLoaded = true;
      
      // Update image ratio for 2D context
      imageRatio = origW / origH;

      if (imgWidthInput) imgWidthInput.value = origW;
      if (imgHeightInput) imgHeightInput.value = origH;

      if (canvasImgWidthInput && (!canvasImgWidthInput.value || canvasImgWidthInput.value === "0")) {
        canvasImgWidthInput.value = origW;
      }
      if (canvasImgHeightInput && (!canvasImgHeightInput.value || canvasImgHeightInput.value === "0")) {
        canvasImgHeightInput.value = origH;
      }

      updatePreview();
      setTimeout(() => { 
        updateThreePreview(); 
        // FIX: Force render 2D context after image loads
        render();
      }, 50);
      hideLoading();
      resolve(img);
    };

    img.onerror = (err) => {
      clearTimeout(timeoutId);
      console.error("❌ Failed to load image:", err);

      if (imgSrc.startsWith('data:image')) {
        setTimeout(() => { img.src = imgSrc; }, 500);
        return;
      }

      isImageLoaded = false;
      hideLoading();
      reject(err);
    };

    img.src = imgSrc;

    if (img.complete) {
      img.onload();
    }
  });
