  function drawImageSliceToCanvas(img, sx, sy, sw, sh, scaleX, scaleY, fillStyle = "#ffffff") {
    const previewCanvas = createPreviewCanvas(sw, sh);
    const previewCtx = previewCanvas.getContext("2d");
    if (!previewCtx) return previewCanvas;

    previewCtx.fillStyle = fillStyle;
    previewCtx.fillRect(0, 0, previewCanvas.width, previewCanvas.height);

    let srcX = Math.round(sx * scaleX);
    let srcY = Math.round(sy * scaleY);
    let srcW = Math.round(sw * scaleX);
    let srcH = Math.round(sh * scaleY);

    if (srcW <= 0 || srcH <= 0) {
      return previewCanvas;
    }

    const clipLeft = Math.max(0, -srcX);
    const clipTop = Math.max(0, -srcY);
    const clipRight = Math.max(0, srcX + srcW - img.width);
    const clipBottom = Math.max(0, srcY + srcH - img.height);

    let destX = (clipLeft / srcW) * previewCanvas.width;
    let destY = (clipTop / srcH) * previewCanvas.height;
    let destW = previewCanvas.width - ((clipLeft + clipRight) / srcW) * previewCanvas.width;
    let destH = previewCanvas.height - ((clipTop + clipBottom) / srcH) * previewCanvas.height;

    srcX += clipLeft;
    srcY += clipTop;
    srcW -= clipLeft + clipRight;
    srcH -= clipTop + clipBottom;

    if (srcW > 0 && srcH > 0 && destW > 0 && destH > 0) {
      previewCtx.imageSmoothingEnabled = true;
      previewCtx.drawImage(img, srcX, srcY, srcW, srcH, destX, destY, destW, destH);
    }

    return previewCanvas;
  }

  function createMirroredEdgeCanvas(sourceCanvas, direction, targetSize) {
    if (!sourceCanvas || !targetSize) {
      return createPreviewCanvas(1, 1);
    }

    const width = Math.max(1, Math.round(direction === "left" || direction === "right" ? targetSize : sourceCanvas.width));
    const height = Math.max(1, Math.round(direction === "top" || direction === "bottom" ? targetSize : sourceCanvas.height));
    const mirrorCanvas = createPreviewCanvas(width, height);
    const mirrorCtx = mirrorCanvas.getContext("2d");
    if (!mirrorCtx) return mirrorCanvas;

    const sampleWidth = Math.max(1, Math.min(sourceCanvas.width, width));
    const sampleHeight = Math.max(1, Math.min(sourceCanvas.height, height));

    mirrorCtx.imageSmoothingEnabled = true;

    if (direction === "left") {
      mirrorCtx.save();
      mirrorCtx.translate(width, 0);
      mirrorCtx.scale(-1, 1);
      mirrorCtx.drawImage(sourceCanvas, 0, 0, sampleWidth, sourceCanvas.height, 0, 0, width, height);
      mirrorCtx.restore();
      return mirrorCanvas;
    }

    if (direction === "right") {
      mirrorCtx.save();
      mirrorCtx.translate(width, 0);
      mirrorCtx.scale(-1, 1);
      mirrorCtx.drawImage(
        sourceCanvas,
        Math.max(0, sourceCanvas.width - sampleWidth),
        0,
        sampleWidth,
        sourceCanvas.height,
        0,
        0,
        width,
        height
      );
      mirrorCtx.restore();
      return mirrorCanvas;
    }

    if (direction === "top") {
      mirrorCtx.save();
      mirrorCtx.translate(0, height);
      mirrorCtx.scale(1, -1);
      mirrorCtx.drawImage(sourceCanvas, 0, 0, sourceCanvas.width, sampleHeight, 0, 0, width, height);
      mirrorCtx.restore();
      return mirrorCanvas;
    }

    mirrorCtx.save();
    mirrorCtx.translate(0, height);
    mirrorCtx.scale(1, -1);
    mirrorCtx.drawImage(
      sourceCanvas,
      0,
      Math.max(0, sourceCanvas.height - sampleHeight),
      sourceCanvas.width,
      sampleHeight,
      0,
      0,
      width,
      height
    );
    mirrorCtx.restore();
    return mirrorCanvas;
  }

  function buildPreviewAssetsFromLoadedImage() {
    if (!loadedImg || !loadedImg.naturalWidth) {
      return null;
    }

    const origWidth = Number(getVal("org-w")) || loadedImg.naturalWidth || 0;
    const origHeight = Number(getVal("org-h")) || loadedImg.naturalHeight || 0;
    const depthRatio = Number(getVal("r")) || 1;

    const largeDimensionPairs = [
      [2200, 2200], [1800, 1800], [1800, 2200],
      [2200, 2600], [2400, 3000], [3000, 4200]
    ];
    const isLargeOriginal = largeDimensionPairs.some(
      ([w, h]) => (origWidth === w && origHeight === h) || (origWidth === h && origHeight === w)
    );

    let depthValue;
    if (isLargeOriginal) {
      depthValue = 300 / depthRatio;
    } else {
      depthValue = 150 / depthRatio;
    }

    const ratio = +(ratioInput ? ratioInput.value : 1) || 1;
    const depth = depthValue * ratio;
    const fW = ((+(fWidthInput ? fWidthInput.value : 500) || 500) - 2 * depthValue) * ratio;
    const fH = ((+(fHeightInput ? fHeightInput.value : 400) || 400) - 2 * depthValue) * ratio;

    const scale = +(scaleInput ? scaleInput.value : 1) || 1;
    const offsetX = (-(+(leftOffsetInput ? leftOffsetInput.value : 0) || 0)) * ratio;
    const offsetY = (-(+(topOffsetInput ? topOffsetInput.value : 0) || 0)) * ratio;

    let effW, effH;
    if (useCustomSize && useCustomSize.checked) {
      effW = +(canvasImgWidthInput ? canvasImgWidthInput.value : loadedImg.naturalWidth) || loadedImg.naturalWidth;
      effH = +(canvasImgHeightInput ? canvasImgHeightInput.value : loadedImg.naturalHeight) || loadedImg.naturalHeight;
    } else {
      effW = origWidth * scale * ratio;
      effH = origHeight * scale * ratio;
    }

    if (!effW || !effH || !fW || !fH || !depth) {
      return null;
    }

    const scaleX = loadedImg.naturalWidth / effW;
    const scaleY = loadedImg.naturalHeight / effH;
    const baseWrapType = document.getElementById("final-image-type-data")?.value || "FitToEdge";
    const isMirrorMode = document.getElementById("mirror-mode-data")?.value === "true";
    const wrapType = isMirrorMode ? "MirrorWrap" : baseWrapType;
    const edgeFill = baseWrapType === "BlackWrap" ? "#111111" : "#ffffff";
    const frontCanvas = drawImageSliceToCanvas(loadedImg, offsetX + depth, offsetY + depth, fW, fH, scaleX, scaleY, edgeFill);

    let leftCanvas;
    let rightCanvas;
    let topCanvas;
    let bottomCanvas;

    if (wrapType === "MirrorWrap") {
      leftCanvas = createMirroredEdgeCanvas(frontCanvas, "left", depth);
      rightCanvas = createMirroredEdgeCanvas(frontCanvas, "right", depth);
      topCanvas = createMirroredEdgeCanvas(frontCanvas, "top", depth);
      bottomCanvas = createMirroredEdgeCanvas(frontCanvas, "bottom", depth);
    } else {
      leftCanvas = drawImageSliceToCanvas(loadedImg, offsetX, offsetY + depth, depth, fH, scaleX, scaleY, edgeFill);
      rightCanvas = drawImageSliceToCanvas(loadedImg, offsetX + depth + fW, offsetY + depth, depth, fH, scaleX, scaleY, edgeFill);
      topCanvas = drawImageSliceToCanvas(loadedImg, offsetX + depth, offsetY, fW, depth, scaleX, scaleY, edgeFill);
      bottomCanvas = drawImageSliceToCanvas(loadedImg, offsetX + depth, offsetY + depth + fH, fW, depth, scaleX, scaleY, edgeFill);
    }

    return {
      wrapType,
      frontCanvas,
      leftCanvas,
      rightCanvas,
      topCanvas,
      bottomCanvas,
      edgeSize: depth,
      frontWidth: fW,
      frontHeight: fH
    };
  }

  function resolvePreviewAssets() {
    const editorAssets = getEditorPreviewAssets();
    if (editorAssets?.frontCanvas && editorAssets?.rightCanvas && editorAssets?.topCanvas) {
      return editorAssets;
    }

    const generatedAssets = buildPreviewAssetsFromLoadedImage();
    if (generatedAssets?.frontCanvas && generatedAssets?.rightCanvas && generatedAssets?.topCanvas) {
      return generatedAssets;
    }

    if (previewAssets?.frontCanvas && previewAssets?.rightCanvas && previewAssets?.topCanvas) {
      return previewAssets;
    }

    return null;
  }

  function checkIfImageExists() {
