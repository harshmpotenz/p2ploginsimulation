  function drawCover(img, x, y, w, h) {
    if (!ctx) return;
    const imgRatio = img.width / img.height;
    const boxRatio = w / h;
    let drawW, drawH;
    if (imgRatio > boxRatio) {
        drawH = h;
        drawW = h * imgRatio;
    } else {
        drawW = w;
        drawH = w / imgRatio;
    }
    const dx = x + (w - drawW) * 0.5;
    const dy = y + (h - drawH) * 0.5;
    ctx.drawImage(img, dx, dy, drawW, drawH);
  }

