  // ============================================
  // TEXTURE CREATION
  // ============================================
  function makeFaceTexture(img, sx, sy, sw, sh, scaleX, scaleY, side, flipX = false, flipY = false) {
    if (!img || !img.naturalWidth) {
      console.warn('⚠️ Invalid image in makeFaceTexture');
      return new THREE.CanvasTexture(document.createElement('canvas'));
    }

    const maxSize = 1024;
    let ix = Math.round(sx * scaleX), iy = Math.round(sy * scaleY);
    let iw = Math.round(sw * scaleX), ih = Math.round(sh * scaleY);
    if (iw <= 0 || ih <= 0) {
      console.warn(`⚠️ Invalid texture dimensions: ${iw}x${ih}`);
      return new THREE.CanvasTexture(document.createElement('canvas'));
    }

    const sourceAspect = iw / ih;
    let texSizeW, texSizeH;
    if (sourceAspect > 1) {
      texSizeW = maxSize;
      texSizeH = Math.max(1, Math.round(maxSize / sourceAspect));
    } else {
      texSizeH = maxSize;
      texSizeW = Math.max(1, Math.round(maxSize * sourceAspect));
    }

    const cvs = document.createElement("canvas");
    cvs.width = texSizeW;
    cvs.height = texSizeH;
    const ctx = cvs.getContext("2d");
    ctx.imageSmoothingQuality = "high";
    ctx.fillStyle = "white";
    ctx.fillRect(0, 0, texSizeW, texSizeH);

    let srcX = ix, srcY = iy, srcW = iw, srcH = ih;
    const clipLeft = Math.max(0, -srcX);
    const clipTop = Math.max(0, -srcY);
    const clipRight = Math.max(0, srcX + srcW - img.width);
    const clipBottom = Math.max(0, srcY + srcH - img.height);
    let destX = (clipLeft / iw) * texSizeW;
    let destY = (clipTop / ih) * texSizeH;
    let destW = texSizeW - ((clipLeft + clipRight) / iw) * texSizeW;
    let destH = texSizeH - ((clipTop + clipBottom) / ih) * texSizeH;
    srcX += clipLeft;
    srcY += clipTop;
    srcW -= clipLeft + clipRight;
    srcH -= clipTop + clipBottom;

    if (srcW > 0 && srcH > 0 && destW > 0 && destH > 0) {
      ctx.save();
      if (flipX) { ctx.scale(-1, 1); ctx.translate(-texSizeW, 0); destX = texSizeW - destX - destW; }
      if (flipY) { ctx.scale(1, -1); ctx.translate(0, -texSizeH); destY = texSizeH - destY - destH; }
      ctx.drawImage(img, srcX, srcY, srcW, srcH, destX, destY, destW, destH);
      ctx.restore();
    }

    const tex = new THREE.CanvasTexture(cvs);
    tex.wrapS = tex.wrapT = THREE.ClampToEdgeWrapping;
    tex.minFilter = tex.magFilter = THREE.LinearFilter;
    tex.colorSpace = THREE.SRGBColorSpace;
    tex.needsUpdate = true;
    return tex;
  }

  function disposeObject3D(object) {
    if (!object) return;

    object.traverse((child) => {
      if (child.geometry) {
        child.geometry.dispose();
      }

      if (child.material) {
        const materials = Array.isArray(child.material) ? child.material : [child.material];
        materials.forEach((material) => {
          if (material.map) material.map.dispose();
          material.dispose();
        });
      }
    });
  }

  function createCanvasTexture(sourceCanvas) {
    const texture = new THREE.CanvasTexture(sourceCanvas);
    texture.wrapS = texture.wrapT = THREE.ClampToEdgeWrapping;
    texture.minFilter = texture.magFilter = THREE.LinearFilter;
    texture.colorSpace = THREE.SRGBColorSpace;
    texture.needsUpdate = true;
    return texture;
  }

  // ============================================
  // MITERED BACKFOLD GEOMETRY
  // ============================================
  function createMiteredBackfoldGeometry(isVertical, mainSize, foldSize, flipped = false) {
    const geometry = new THREE.BufferGeometry();
    const positions = [];
    const uvs = [];
    const m = foldSize;

    if (isVertical) {
      positions.push(
        0, -mainSize / 2, 0,
        m, -mainSize / 2 + m, 0,
        m, mainSize / 2 - m, 0,
        0, mainSize / 2, 0
      );
      let uv = [0, 0, 1, m / mainSize, 1, 1 - m / mainSize, 0, 1];
      if (flipped) uv = [1, 0, 0, m / mainSize, 0, 1 - m / mainSize, 1, 1];
      uvs.push(...uv);
    } else {
      positions.push(
        -mainSize / 2, 0, 0,
        -mainSize / 2 + m, m, 0,
        mainSize / 2 - m, m, 0,
        mainSize / 2, 0, 0
      );
      let uv = [0, 0, m / mainSize, 1, 1 - m / mainSize, 1, 1, 0];
      if (flipped) uv = [0, 1, m / mainSize, 0, 1 - m / mainSize, 0, 1, 1];
      uvs.push(...uv);
    }

    geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
    geometry.setAttribute('uv', new THREE.Float32BufferAttribute(uvs, 2));
    geometry.setIndex([0, 1, 2, 0, 2, 3]);
    geometry.computeVertexNormals();
    return geometry;
  }

