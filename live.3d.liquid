            camera.updateProjectionMatrix();
          }
          lastTouchDistance = dist;
        }
      }, { passive: false });

      container.addEventListener("touchend", (e) => {
        if (e.touches.length < 2) {
          isPinching = false;
          lastTouchDistance = null;
        }
      });

      // Mouse drag
      let isDragging = false;
      let previousMouse = { x: 0, y: 0 };
      container.addEventListener("pointerdown", e => {
        isDragging = true;
        previousMouse.x = e.clientX;
        previousMouse.y = e.clientY;
        container.style.cursor = "grabbing";
      });

      window.addEventListener("pointerup", () => {
        isDragging = false;
        container.style.cursor = "grab";
      });

      window.addEventListener("pointermove", e => {
        if (!isDragging || !wrapGroup || isPinching) return;
        wrapGroup.rotation.y += (e.clientX - previousMouse.x) * 0.004;
        wrapGroup.rotation.x += (e.clientY - previousMouse.y) * 0.004;
        previousMouse.x = e.clientX;
        previousMouse.y = e.clientY;
      });

      container.addEventListener("selectstart", e => e.preventDefault());
      container.addEventListener("wheel", e => {
        e.preventDefault();
        if (camera) {
          camera.fov = THREE.MathUtils.clamp(camera.fov + e.deltaY * 0.06, 20, 110);
          camera.updateProjectionMatrix();
        }
      }, { passive: false });
    }

    // Resize observer for Three.js
    if (container && camera && renderer) {
      const resizeObserver = new ResizeObserver(entries => {
        for (let entry of entries) {
          if (entry.target === container && container.offsetParent !== null) {
            if (camera && renderer) {
              const width = container.clientWidth;
              const height = container.clientHeight;
              if (width > 0 && height > 0) {
                renderer.setSize(width, height);
                camera.aspect = width / height;
                camera.updateProjectionMatrix();
                renderer.render(scene, camera);
              }
            }
          }
        }
      });
      resizeObserver.observe(container);
    }

    // Window resize
    window.addEventListener("resize", () => {
      if (camera && renderer && container) {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      }
      if (previewAssets?.frontCanvas) {
        renderCanvasPreviewsFromAssets(previewAssets);
      }
      render(); // Also update 2D render on resize
    });
  }

  // ============================================
  // ANIMATION LOOP
  // ============================================
  function animate() {
    requestAnimationFrame(animate);
    if (renderer && scene && camera) {
      renderer.render(scene, camera);
    }
  }

  // ============================================
  // INPUT LISTENERS
  // ============================================
  function setupInputListeners() {
    // Upload event listener
    if (upload) {
      upload.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const img = new Image();
        img.onload = () => {
          imageSrc = img.src;
          imageRatio = img.naturalWidth / img.naturalHeight;
          if (imgWidthInput) imgWidthInput.value = img.naturalWidth;
          if (imgHeightInput) imgHeightInput.value = img.naturalHeight;
          artImage.src = imageSrc;
          render();
        };
        img.src = URL.createObjectURL(file);
      });
    } else {
      console.error("Upload input not found");
    }

    if (imgWidthInput) {
      imgWidthInput.addEventListener("input", () => {
        if (lockAspect && lockAspect.checked && imgHeightInput && imageRatio) {
          imgHeightInput.value = Math.round(imgWidthInput.value / imageRatio);
        }
        render();
      });
    }

    if (imgHeightInput) {
      imgHeightInput.addEventListener("input", () => {
        if (lockAspect && lockAspect.checked && imgWidthInput && imageRatio) {
          imgWidthInput.value = Math.round(imgHeightInput.value * imageRatio);
        }
        render();
      });
    }

    if (canvasImgWidthInput) {
      canvasImgWidthInput.addEventListener("input", () => {
        if (lockAspect && lockAspect.checked && canvasImgHeightInput && aspect) {
          canvasImgHeightInput.value = Math.round(canvasImgWidthInput.value * aspect);
        }
        updatePreview();
        updateThreePreview();
      });
    }

    if (previewImgWidthInput) {
      previewImgWidthInput.addEventListener("input", () => {
        if (lockAspect && lockAspect.checked && previewImgHeightInput && aspect) {
          previewImgHeightInput.value = Math.round(previewImgWidthInput.value * aspect);
        }
        updatePreview();
        updateThreePreview();
      });
    }


    if (canvasImgHeightInput) {
      canvasImgHeightInput.addEventListener("input", () => {
        if (lockAspect && lockAspect.checked && canvasImgWidthInput && aspect) {
          canvasImgWidthInput.value = Math.round(canvasImgHeightInput.value / aspect);
        }
        updatePreview();
        updateThreePreview();
      });
    }

     if (previewImgHeightInput) {
      previewImgWidthInput.addEventListener("input", () => {
        if (lockAspect && lockAspect.checked && previewImgHeightInput && aspect) {
          previewImgHeightInput.value = Math.round(previewImgWidthInput.value / aspect);
        }
        updatePreview();
        updateThreePreview();
      });
    }
    const inputElements = [
      fWidthInput, fHeightInput, depthInput, ratioInput, scaleInput,
      leftOffsetInput, topOffsetInput, backFoldInput
    ];
    
    inputElements.forEach(el => {
      if (el) {
        el.addEventListener("input", function() {
          updatePreview();
          updateThreePreview();
        });
      }
    });

    if (lockAspect) {
      lockAspect.addEventListener("change", () => {
        render();
        updatePreview();
        updateThreePreview();
      });
    }

    if (useCustomSize) {
      useCustomSize.addEventListener("change", () => {
        updatePreview();
        updateThreePreview();
      });
    }

    if (scaleInput) {
      scaleInput.addEventListener('input', () => {
        render();
      });
    }

      if (zoom) {
    zoom.addEventListener('input', () => {
      window._userAdjustedZoom = true;
      render();
    });
  }

  if (frameBottom) {
    frameBottom.addEventListener('input', () => {
      window._userAdjustedDistance = true;
      render();
    });
  }

  // Also track when original dimensions change to potentially reset auto values
  if (origfWidthInput && origfHeightInput) {
    const handleOrigChange = () => {
      // Reset user adjustment flags when dimensions change significantly
      // Only reset if you want to reapply auto settings on dimension change
      const settings = calculateContextSettings();
      
      // Option 1: Reset flags to reapply auto settings
      // window._userAdjustedZoom = false;
      // window._userAdjustedDistance = false;
      
      // Option 2: Keep user adjustments but update if user hasn't adjusted
      if (!window._userAdjustedZoom && zoom) {
        zoom.value = settings.bgZoom;
        if (zoomValue) zoomValue.innerText = settings.bgZoom.toFixed(2);
      }
      if (!window._userAdjustedDistance && frameBottom) {
        frameBottom.value = settings.boxDistance;
        if (bottomValue) bottomValue.innerText = Math.round(settings.boxDistance) + 'px';
      }
      
      render();
    };
    
    origfWidthInput.addEventListener('input', handleOrigChange);
    origfHeightInput.addEventListener('input', handleOrigChange);
  }
  }

  // ============================================
  // POPUP HANDLING
  // ============================================
  function setupPopupHandling() {
    if (previewBtn) {
      previewBtn.addEventListener("click", async function (e) {
        e.preventDefault();
        await openCanvasPreview();
      });
    } else {
      console.error("❌ Preview button not found with selector '#preview-popup'");
    }

    if (closeNoImageMessage) {
      closeNoImageMessage.addEventListener("click", () => {
        if (noImageMessage) noImageMessage.classList.remove("active");
      });
    }

    if (noImageMessage) {
      noImageMessage.addEventListener("click", (e) => {
        if (e.target === noImageMessage) {
          noImageMessage.classList.remove("active");
        }
      });
    }

    const closeBtn = document.getElementById("closeCanvasPopup");
    if (closeBtn) {
      closeBtn.addEventListener("click", () => {
        if (popup) popup.classList.remove("active");
        isImageLoaded = false;
        hideLoading();
      });
    }

    if (popup) {
      popup.addEventListener("click", e => {
        if (e.target === popup) {
          popup.classList.remove("active");
          isImageLoaded = false;
          hideLoading();
        }
      });
    }
  }

  // ============================================
  // GLOBAL API (callable from anywhere)
  // ============================================
  async function openCanvasPreview() {
  if (!checkIfImageExists()) {
    if (noImageMessage) noImageMessage.classList.add("active");
    return false;
  }

  if (popup) popup.classList.add("active");
  showLoading();
  isImageLoaded = false;
  imageURL = null;
  
  // Reset user adjustment flags when opening preview
  window._userAdjustedZoom = false;
  window._userAdjustedDistance = false;
  
  setInputsFromSourceIds();
  await autoLoadImageToCanvas();
  
  // Apply initial settings based on dimensions
  const settings = calculateContextSettings();
  if (zoom) {
    zoom.value = settings.bgZoom;
    if (zoomValue) zoomValue.innerText = settings.bgZoom.toFixed(2);
  }
  if (frameBottom) {
    frameBottom.value = settings.boxDistance;
    if (bottomValue) bottomValue.innerText = Math.round(settings.boxDistance) + 'px';
  }
  
  // Store background position values for use in render
  window._currentBgTop = settings.bgTop;
  window._currentBgLeft = settings.bgLeft;
  
  // Ensure context1 renders after opening
  setTimeout(() => {
    render();
  }, 200);
  
  return true;
}
  
  async function threedCanvasPreview() {
    if (!checkIfImageExists()) {
      if (noImageMessage) noImageMessage.classList.add("active");
      return false;
    }
    showLoading();
    isImageLoaded = false;
    imageURL = null;
    setInputsFromSourceIds();
    await autoLoadImageToCanvas();
    return true;
  }

  function closeCanvasPreview() {
    if (!popup) return;
    popup.classList.remove("active");
    isImageLoaded = false;
    hideLoading();
  }

  function exposeGlobalCanvasApi() {
    const api = {
      showLoading,
      hideLoading,
      showToast,
      getVal,
      checkIfImageExists,
      findAndLoadImage,
      setInputsFromSourceIds,
      applyCanvasAngle,
      initThree,
      makeFaceTexture,
      createMiteredBackfoldGeometry,
      updatePreview,
      updateThreePreview,
      loadImage,
      autoLoadImageToCanvas,
      setupInteractions,
      setupInputListeners,
      setupPopupHandling,
      render, // Expose render function
      open: openCanvasPreview,
      close: closeCanvasPreview,
      threedopen: threedCanvasPreview,
      init
    };

    window.Canvas3DPreview = api;
    window["threedpreview"] = threedCanvasPreview;
    window["open3dpreview"] = openCanvasPreview;
    window["close3dpreview"] = closeCanvasPreview;
  }

  // ============================================
  // MAIN INITIALIZATION
  // ============================================
  function init() {
    console.log("🚀 Initializing Canvas Wrap Preview");

    initThree();
    setupInteractions();
    setupInputListeners();
    setupPopupHandling();
    exposeGlobalCanvasApi();
    animate();

    // Initial set inputs
    setTimeout(() => {
      if (fWidthInput && !fWidthInput.value) {
        setInputsFromSourceIds();
      }
      render(); // Initial render for context1
    }, 100);
  }

  // Start everything when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  
  // Split view functionality (only if elements exist)
const toggle = document.getElementById("toggleSplit");
const divider = document.getElementById("divider");
const containersplit = document.getElementById("splitView");

if (toggle && divider && containersplit) {

  const left = containersplit.querySelector(".canvas-panel.left-panel");
  const right = containersplit.querySelector(".canvas-panel.right-panel");

  let isDragging = false;

  function applyLayout() {

    const isMobile = window.innerWidth <= 900;

    if (toggle.checked) {

      // DESKTOP
      if (!isMobile) {

        if (left) left.style.width = "50%";
        if (right) right.style.width = "50%";

        if (right) {
          right.classList.remove("hide-wrap");
          right.classList.add("show-flex");
        }

        if (divider) {
          divider.classList.remove("hide-wrap");
          divider.classList.add("show-flex");
        }

      }

      // MOBILE → SHOW ONLY 3D
      else {

        if (left) {
          left.style.width = "0%";
          left.classList.add("hide-wrap");
        }

        if (right) {
          right.style.width = "100%";
          right.classList.remove("hide-wrap");
          right.classList.add("show-flex");
        }

        if (divider) divider.classList.add("hide-wrap");
      }

      setTimeout(() => {
        if (right && container) {
          const rect = right.getBoundingClientRect();
          container.style.width = rect.width + "px";
          container.style.height = rect.height + "px";
        }
      }, 100);

    } else {

      // SHOW ONLY CANVAS

      if (left) {
        left.style.width = "100%";
        left.classList.remove("hide-wrap");
      }

      if (right) {
        right.classList.add("hide-wrap");
        right.classList.remove("show-flex");
      }

      if (divider) {
        divider.classList.add("hide-wrap");
        divider.classList.remove("show-flex");
      }

      setTimeout(() => {
        if (left && container) {
          const rect = left.getBoundingClientRect();
          container.style.width = rect.width + "px";
          container.style.height = rect.height + "px";
        }
      }, 100);
    }
  }

  // TOGGLE
  toggle.addEventListener("change", function () {

    applyLayout();

    if (this.checked) {

      if (!checkIfImageExists()) {
        if (noImageMessage) noImageMessage.classList.add("active");
        return;
      }

      setTimeout(resizeThree, 100);
      showLoading();
      isImageLoaded = false;
      imageURL = null;
      setInputsFromSourceIds();

      setTimeout(() => {
        autoLoadImageToCanvas();
      }, 100);
    }
  });

  function resizeThree() {
    if (right && renderer && camera && container) {
      const rect = right.getBoundingClientRect();
      container.style.width = rect.width + "px";
      container.style.height = rect.height + "px";
      renderer.setSize(rect.width, rect.height);
      camera.aspect = rect.width / rect.height;
      camera.updateProjectionMatrix();
    }
  }

  // MOUSE DOWN
  divider.addEventListener("mousedown", function () {

    if (!toggle.checked) return;
    if (window.innerWidth <= 900) return; // disable drag on mobile

    isDragging = true;
  });

  // MOUSE MOVE
  document.addEventListener("mousemove", function (e) {

    if (!isDragging) return;

    const rect = containersplit.getBoundingClientRect();
    let offsetX = e.clientX - rect.left;
    let percent = (offsetX / rect.width) * 100;

    percent = Math.max(30, Math.min(70, percent));

    if (left) left.style.width = percent + "%";
    if (right) right.style.width = (100 - percent) + "%";

    setTimeout(resizeThree, 100);
  });

  // MOUSE UP
  document.addEventListener("mouseup", function () {
    isDragging = false;
  });

}

})();
</script>

