    bgZoom = 1.25;
    boxDistance = 180;
    boxZoom = 1.25;
    bgTop = -80;
    bgLeft = -20;
  }
  // Add your other dimension combinations here...
  
  return { bgZoom, boxDistance, boxZoom, bgTop, bgLeft };
}

