        gradient.addColorStop(0, '#d0d5db');
        gradient.addColorStop(1, '#b8c1cc');
        ctx.fillStyle = gradient;
        ctx.fillRect(artX, artY, imgW, imgH);
    }
    ctx.restore();

    ctx.strokeStyle = 'rgba(255,255,255,0.35)';
    ctx.lineWidth = 1;
    ctx.strokeRect(innerX + 0.5, innerY + 0.5, Math.max(0, innerW - 1), Math.max(0, innerH - 1));

    // --- dynamic max zoom to prevent overflow (nice to have) ---
    const VH = stageH;
    const occupied = baseBottom + realCanvasH * baseRatio;
    const maxZoomCalc = (0.95 * VH) / occupied;
    const newMax = Math.min(2, Math.max(0.5, maxZoomCalc));
    if (zoom) {
        zoom.setAttribute('max', newMax.toFixed(2));
        if (parseFloat(zoom.value) > newMax) {
            zoom.value = newMax.toFixed(2);
            render(); // re-entrant but safe with condition
        }
    }
    if (zoomValue) zoomValue.innerText = parseFloat(zoom ? zoom.value : 1).toFixed(2);
