                                  {% assign pixel_size_desktop = parts[1] %}
                                {% endif %}
                              {% endfor %}

                              {% for pair in pixel_pairs_mobile %}
                                {% assign parts = pair | split: ':' %}
                                {% if parts[0] == value %}
                                  {% assign pixel_size_mobile = parts[1] %}
                                {% endif %}
                              {% endfor %}

                              {% for pair in ratio_pairs_desktop %}
                                {% assign parts = pair | split: ':' %}
                                {% if parts[0] == value %}
