                                {% endif %}
                              {% endfor %}

                              {% for pair in ratio_pairs_mobile %}
                                {% assign parts = pair | split: ':' %}
                                {% if parts[0] == value %}
                                  {% assign pixel_ratio_size_mobile = parts[1] %}
                                {% endif %}
                              {% endfor %}

                            {% comment %} Override preview sizes using real dimensions scaled down {% endcomment %}
