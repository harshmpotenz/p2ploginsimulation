                                data-ratio-mobile="{{ pixel_ratio_size_mobile }}"
                                data-p-ratio="{{ image_p_ratio_size }}"
                                data-l-ratio="{{ image_l_ratio_size }}"
                                {% if forloop.first %}checked{% endif %}
                              >
                              <span>{{ value }}</span>
                            </label>
