                              {% if parts[0] == value %}
                                {% assign image_p_ratio_size = parts[1] %}
                              {% endif %}
                            {% endfor %}

                            {% comment %} Get l-ratio size {% endcomment %}
                            {% for pair in l_ratio_pairs %}
