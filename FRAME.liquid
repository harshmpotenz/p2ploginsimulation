                  </label>

                  <!-- Select Button -->
                  <button
                    type="button"
                    class="upload-btn"
                    onclick="window.location.href='/pages/image-collection?syncMode=select-print&returnUrl=' + encodeURIComponent(window.location.pathname)"
                  >
                    Select Your Image
