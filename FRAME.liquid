                              {% if parts[0] == value %}
                                {% assign pixel_ratio_size = parts[1] %}
                              {% endif %}
                            {% endfor %}

                            {% comment %} Get p-ratio size {% endcomment %}
                            {% for pair in p_ratio_pairs %}
