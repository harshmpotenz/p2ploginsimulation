<script>
document.addEventListener("DOMContentLoaded", function () {
  const currentUrl = new URL(window.location.href);
  const syncMode = currentUrl.searchParams.get("syncMode");
  const syncImage = currentUrl.searchParams.get("syncimage");

  // Apply only for allowed sync modes
  if (syncMode === "select-print" || syncMode === "pdp-select") {
    document.querySelectorAll("#Product a.pdp-tab-link").forEach(link => {
      const url = new URL(link.href, window.location.origin);

      // Set syncMode
      url.searchParams.set("syncMode", syncMode);

      // Set syncimage only if it exists on current page
      if (syncImage) {
        url.searchParams.set("syncimage", syncImage);
      }

      // Force hash
      url.hash = "main";

      link.href = url.toString();
    });
  }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const resetBtns = document.querySelectorAll(".reset-pdp");

  if (!resetBtns.length) return;

  resetBtns.forEach(function (resetBtn) {
    resetBtn.addEventListener("click", function () {
      const url = new URL(window.location.href);

      // Remove sync-related params
      url.searchParams.delete("syncimage");
      url.searchParams.delete("syncMode");

      localStorage.removeItem("pdpUploadedImage");

      window.location.href = url.pathname + url.search;
    });
  });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const preview = document.querySelector(".canvas-edit-wrap") || document.getElementById("image-canvas");
  const btnIn = document.getElementById("preview-zoom-in");
  const btnOut = document.getElementById("preview-zoom-out");
  const btnReset = document.getElementById("preview-zoom-reset");
  const btnPan = document.getElementById("preview-pan-toggle");

  if (!preview || !btnIn || !btnOut || !btnReset || !btnPan) return;

  let previewZoom = 1;
  let offsetX = 0;
  let offsetY = 0;
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let panEnabled = false;

  const minZoom = 0.5;
  const maxZoom = 2;
  const step = 0.1;

  preview.style.transformOrigin = "center center";

  function applyTransform() {
    preview.style.transform = `translate(${offsetX}px, ${offsetY}px) scale(${previewZoom})`;
  }

  function setPanEnabled(enabled) {
    panEnabled = enabled;
    preview.style.cursor = panEnabled ? "grab" : "default";
    btnPan.classList.toggle("active", panEnabled);
    btnPan.style.background = panEnabled ? "#1DB954" : "#ffffff";
    btnPan.style.color = panEnabled ? "#ffffff" : "#000000";
  }

  function onWheel(e) {
    e.preventDefault();
    const direction = e.deltaY > 0 ? -1 : 1;
    const factor = 1 + step * direction;
    previewZoom = Math.max(minZoom, Math.min(maxZoom, previewZoom * factor));
    applyTransform();
  }

  function onMouseDown(e) {
    if (!panEnabled) return;
    isDragging = true;
    preview.style.cursor = "grabbing";
    dragStartX = e.clientX - offsetX;
    dragStartY = e.clientY - offsetY;
  }

  function onMouseMove(e) {
    if (!isDragging) return;
    offsetX = e.clientX - dragStartX;
    offsetY = e.clientY - dragStartY;
    applyTransform();
  }

  function endDrag() {
    if (!isDragging) return;
    isDragging = false;
    preview.style.cursor = panEnabled ? "grab" : "default";
  }

  btnIn.addEventListener("click", () => {
    previewZoom = Math.min(maxZoom, previewZoom + step);
    applyTransform();
  });

  btnOut.addEventListener("click", () => {
    previewZoom = Math.max(minZoom, previewZoom - step);
    applyTransform();
  });

  btnReset.addEventListener("click", () => {
    previewZoom = 1;
    offsetX = 0;
    offsetY = 0;
    applyTransform();
  });

  btnPan.addEventListener("click", () => {
    setPanEnabled(!panEnabled);
  });

  preview.addEventListener("wheel", (e) => {
    if (!panEnabled) return;
    onWheel(e);
  }, { passive: false });
  preview.addEventListener("mousedown", onMouseDown);
  window.addEventListener("mousemove", onMouseMove);
  window.addEventListener("mouseup", endDrag);
  preview.addEventListener("mouseleave", endDrag);
});
</script>
