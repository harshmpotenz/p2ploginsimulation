                            {% assign orig_w = orig_parts[0] | plus: 0 %}
                            {% assign orig_h = orig_parts[1] | plus: 0 %}
                            {% assign scaled_w_desktop = orig_w | divided_by: 3 | round: 0 %}
                            {% assign scaled_h_desktop = orig_h | divided_by: 3 | round: 0 %}
                            {% assign scaled_w_mobile = orig_w | divided_by: 6 | round: 0 %}
                            {% assign scaled_h_mobile = orig_h | divided_by: 6 | round: 0 %}
                            {% assign pixel_size_desktop = scaled_w_desktop | append: 'x' | append: scaled_h_desktop %}
                            {% assign pixel_size_mobile = scaled_w_mobile | append: 'x' | append: scaled_h_mobile %}
                            {% assign pixel_size = pixel_size_desktop %}

