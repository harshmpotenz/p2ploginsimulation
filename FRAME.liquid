                            {% assign pixel_size_mobile = '' %}
                            {% assign pixel_ratio_size_desktop = '' %}
                            {% assign pixel_ratio_size_mobile = '' %}

                            {% comment %} Get pixel size {% endcomment %}
                            {% for pair in pixel_pairs %}
                              {% assign parts = pair | split: ':' %}
                              {% if parts[0] == value %}
                                {% assign pixel_size = parts[1] %}
                              {% endif %}
                            {% endfor %}

                            {% comment %} Get original pixel size {% endcomment %}
                            {% for pair in original_pixel_pairs %}
                              {% assign parts = pair | split: ':' %}
                              {% if parts[0] == value %}
                                {% assign pixel_orignal_size = parts[1] %}
                              {% endif %}
                            {% endfor %}

                            {% comment %} Get ratio size {% endcomment %}
                            {% for pair in ratio_pairs %}
